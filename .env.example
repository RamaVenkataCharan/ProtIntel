# ProtIntel Environment Configuration
# Copy this file to .env and fill in your values

# Device configuration
DEVICE=cpu                          # cpu | cuda | cuda:0 | cuda:1
MODEL_PATH=models/best_checkpoint.pt

# ESM-2 configuration
ESM2_MODEL_NAME=facebook/esm2_t33_650M_UR50D
ESM2_CACHE_DIR=datasets/processed/embeddings

# API configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Wandb (optional)
# WANDB_API_KEY=your_key_here
# WANDB_PROJECT=protintel
# WANDB_ENTITY=your_entity

# HuggingFace (optional, for gated models)
# HF_TOKEN=your_token_here

# Logging
LOG_LEVEL=INFO
